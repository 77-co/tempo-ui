{
  "name": "tempo-ui",
  "version": "0.1.0",
  "description": "Production-ready, composable UI component library for building business websites powered by PayloadCMS",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "tailwind.preset.js"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup && tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --minify",
    "build:watch": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwindcss",
    "payloadcms",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maciej/tempo-ui"
  }
}
